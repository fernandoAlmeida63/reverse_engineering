    public class Pedido
    {
        public int Id { get; set; }
        public Cliente Cliente { get; set; }
        public List<ItemPedido> Itens { get; set; } = new List<ItemPedido>();
        public string Cupom { get; set; }
        public string FormaPagamento { get; set; }
        public double PesoTotal { get; set; }
        public bool EntregaExpressa { get; set; }
        public int Parcelas { get; set; }
        public string Pais { get; set; }
    }

    // 2. Separação de Responsabilidades (Serviços)
    public class CalculadoraFinanceira
    {
        public double CalcularSubtotal(List<ItemPedido> itens) 
            => itens.Sum(i => (i.PrecoUnitario * i.Quantidade) + (i.Categoria == "ALIMENTO" ? 2 : (i.Categoria == "IMPORTADO" ? 5 : 0)));

        public double AplicarJuros(double subtotal, string forma, int parcelas)
        {
            if (forma != "CARTAO") return 0;
            if (parcelas > 6) return subtotal * 0.05;
            if (parcelas > 1) return subtotal * 0.02;
            return 0;
        }
    }

    public class PedidoService
    {
        private readonly CalculadoraFinanceira _calcFinan = new CalculadoraFinanceira();

        public string Processar(Pedido pedido)
        {
            // Validações Iniciais (Fail Fast)
            if (pedido.Cliente.EstaBloqueado) return "Erro: Cliente Bloqueado";
            if (!pedido.Itens.Any()) return "Erro: Pedido sem itens";

            double subtotal = _calcFinan.CalcularSubtotal(pedido.Itens);
            double frete = CalcularFreteCustomizado(pedido);
            double desconto = CalcularDescontoTotal(pedido, subtotal);
            double juros = _calcFinan.AplicarJuros(subtotal, pedido.FormaPagamento, pedido.Parcelas);

            double totalFinal = Math.Max(0, subtotal - desconto + frete + juros);

            return GerarRelatorio(totalFinal, subtotal, pedido);
        }

